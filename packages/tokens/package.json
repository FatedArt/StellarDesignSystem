{
  "name": "@fatedart/tokens",
  "version": "0.0.1",
  "description": "Design tokens for Stellar Design System",
  "main": "dist/tokens.css",
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "prebuild": "node scripts/merge-token-sets.mjs",
    "build": "style-dictionary build --config sd.config.mjs",
    "dev": "node scripts/merge-token-sets.mjs && style-dictionary build --config sd.config.mjs --watch",
    "split": "node scripts/split-token-sets.mjs",
    "merge": "node scripts/merge-token-sets.mjs",
    "clean": "rm -rf dist tokens.json"
  },
  "devDependencies": {
    "style-dictionary": "^4.0.0"
  }
}
