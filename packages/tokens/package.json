{
  "name": "@fatedart/tokens",
  "version": "0.0.1",
  "description": "Design tokens for Stellar Design System",
  "main": "dist/tokens.css",
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "prebuild": "node scripts/ensure-tokens-for-build.mjs",
    "build": "style-dictionary build --config sd.config.mjs && node scripts/wrap-calc-css.mjs",
    "dev": "node scripts/ensure-tokens-for-build.mjs && style-dictionary build --config sd.config.mjs --watch",
    "sync:split": "node scripts/sync-from-tokens-json.mjs",
    "sync:merge": "node scripts/merge-token-sets.mjs",
    "migrate:scale": "node scripts/migrate-color-scale-atlassian.mjs",
    "migrate:hierarchy": "node scripts/migrate-color-hierarchy-atlassian.mjs",
    "split": "node scripts/split-token-sets.mjs",
    "merge": "node scripts/merge-token-sets.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "style-dictionary": "^4.0.0"
  }
}
